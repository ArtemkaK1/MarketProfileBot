//@version=5
strategy("NASDAQ Pre-NYSE IB Extension", overlay=true, max_boxes_count=100, max_lines_count=300, max_labels_count=100)

// Step 2: draw the pre-NYSE Initial Balance and trade only extension entries.

ibSessionInput = input.session("0800-0930", "Pre-NYSE IB session")
tradeSessionInput = input.session("0930-1600", "Trade session")
timezoneInput = input.string("America/New_York", "Session timezone")
fractalLeft = input.int(1, "Fractal left bars", minval=1, maxval=10)
fractalRight = input.int(1, "Fractal right bars", minval=1, maxval=10)
breakoutNeedsClose = input.bool(false, "Breakout must close beyond IB")
emaTimeframe = input.timeframe("15", "EMA timeframe")
emaFastLength = input.int(125, "Fast EMA length", minval=1, maxval=500)
emaSlowLength = input.int(200, "Slow EMA length", minval=1, maxval=500)
showBox = input.bool(true, "Show IB box")
showMid = input.bool(true, "Show IB 0.5")
showEMA = input.bool(true, "Show 15m EMAs")
extendLevels = input.bool(true, "Extend levels right")

tz = timezoneInput
ibSession = ibSessionInput + ":12345"
tradeSession = tradeSessionInput + ":12345"

inIB = not na(time(timeframe.period, ibSession, tz))
inTrade = not na(time(timeframe.period, tradeSession, tz))
newDay = ta.change(time("D", "0000-2359:1234567", tz)) != 0
ibStarted = inIB and not inIB[1]
ibFinished = not inIB and inIB[1]

emaFast = request.security(syminfo.tickerid, emaTimeframe, ta.ema(close, emaFastLength), barmerge.gaps_off, barmerge.lookahead_off)
emaSlow = request.security(syminfo.tickerid, emaTimeframe, ta.ema(close, emaSlowLength), barmerge.gaps_off, barmerge.lookahead_off)
longAllowed = emaFast > emaSlow
shortAllowed = emaFast < emaSlow

var float ibHigh = na
var float ibLow = na
var float ibMid = na
var int ibStartBar = na
var bool ibReady = false
var bool tradeTaken = false

var bool highBreakoutSeen = false
var bool lowBreakoutSeen = false
var int highBreakoutBar = na
var int lowBreakoutBar = na
var float highExtensionFractal = na
var float lowExtensionFractal = na
var bool highFractalReady = false
var bool lowFractalReady = false
var bool highReturnedToIB = false
var bool lowReturnedToIB = false
var bool extensionInvalidated = false

var box ibBox = na
var line ibHighLine = na
var line ibMidLine = na
var line ibLowLine = na
var line highFractalLine = na
var line lowFractalLine = na
var label ibLabel = na

deleteDrawings() =>
    if not na(ibBox)
        box.delete(ibBox)
    if not na(ibHighLine)
        line.delete(ibHighLine)
    if not na(ibMidLine)
        line.delete(ibMidLine)
    if not na(ibLowLine)
        line.delete(ibLowLine)
    if not na(highFractalLine)
        line.delete(highFractalLine)
    if not na(lowFractalLine)
        line.delete(lowFractalLine)
    if not na(ibLabel)
        label.delete(ibLabel)

if newDay
    deleteDrawings()
    ibHigh := na
    ibLow := na
    ibMid := na
    ibStartBar := na
    ibReady := false
    tradeTaken := false
    highBreakoutSeen := false
    lowBreakoutSeen := false
    highBreakoutBar := na
    lowBreakoutBar := na
    highExtensionFractal := na
    lowExtensionFractal := na
    highFractalReady := false
    lowFractalReady := false
    highReturnedToIB := false
    lowReturnedToIB := false
    extensionInvalidated := false
    ibBox := na
    ibHighLine := na
    ibMidLine := na
    ibLowLine := na
    highFractalLine := na
    lowFractalLine := na
    ibLabel := na

if ibStarted
    deleteDrawings()
    ibHigh := high
    ibLow := low
    ibMid := na
    ibStartBar := bar_index
    ibReady := false
    tradeTaken := false
    highBreakoutSeen := false
    lowBreakoutSeen := false
    highBreakoutBar := na
    lowBreakoutBar := na
    highExtensionFractal := na
    lowExtensionFractal := na
    highFractalReady := false
    lowFractalReady := false
    highReturnedToIB := false
    lowReturnedToIB := false
    extensionInvalidated := false
    ibBox := na
    ibHighLine := na
    ibMidLine := na
    ibLowLine := na
    highFractalLine := na
    lowFractalLine := na
    ibLabel := na

if inIB
    ibHigh := na(ibHigh) ? high : math.max(ibHigh, high)
    ibLow := na(ibLow) ? low : math.min(ibLow, low)
    if showBox
        if na(ibBox)
            ibBox := box.new(ibStartBar, ibHigh, bar_index, ibLow, bgcolor=color.new(color.blue, 88), border_color=color.new(color.blue, 20))
        else
            box.set_left(ibBox, ibStartBar)
            box.set_right(ibBox, bar_index)
            box.set_top(ibBox, ibHigh)
            box.set_bottom(ibBox, ibLow)

if ibFinished and not na(ibHigh) and not na(ibLow)
    ibMid := (ibHigh + ibLow) / 2.0
    ibReady := true
    x2 = extendLevels ? bar_index + 1 : bar_index
    levelExtend = extendLevels ? extend.right : extend.none
    ibHighLine := line.new(bar_index, ibHigh, x2, ibHigh, extend=levelExtend, color=color.new(color.red, 0), width=2)
    if showMid
        ibMidLine := line.new(bar_index, ibMid, x2, ibMid, extend=levelExtend, color=color.new(color.gray, 0), width=1, style=line.style_dashed)
    ibLowLine := line.new(bar_index, ibLow, x2, ibLow, extend=levelExtend, color=color.new(color.green, 0), width=2)
    ibLabel := label.new(bar_index, ibHigh, "Pre-NYSE IB", style=label.style_label_down, color=color.new(color.blue, 0), textcolor=color.white)

highBreakout = ibReady and inTrade and not tradeTaken and not highBreakoutSeen and not lowBreakoutSeen and (breakoutNeedsClose ? close > ibHigh : high > ibHigh)
lowBreakout = ibReady and inTrade and not tradeTaken and not highBreakoutSeen and not lowBreakoutSeen and not highBreakout and (breakoutNeedsClose ? close < ibLow : low < ibLow)

if highBreakout
    highBreakoutSeen := true
    highBreakoutBar := bar_index
if lowBreakout
    lowBreakoutSeen := true
    lowBreakoutBar := bar_index

pivotHigh = ta.pivothigh(high, fractalLeft, fractalRight)
pivotLow = ta.pivotlow(low, fractalLeft, fractalRight)
pivotBar = bar_index - fractalRight

newHighExtensionFractal = highBreakoutSeen and not na(pivotHigh) and pivotBar >= highBreakoutBar and pivotHigh > ibHigh
newLowExtensionFractal = lowBreakoutSeen and not na(pivotLow) and pivotBar >= lowBreakoutBar and pivotLow < ibLow

if newHighExtensionFractal
    highExtensionFractal := pivotHigh
    highFractalReady := true
    if not na(highFractalLine)
        line.delete(highFractalLine)
    highFractalLine := line.new(pivotBar, highExtensionFractal, bar_index + 1, highExtensionFractal, extend=extend.right, color=color.new(color.yellow, 0), width=2)

if newLowExtensionFractal
    lowExtensionFractal := pivotLow
    lowFractalReady := true
    if not na(lowFractalLine)
        line.delete(lowFractalLine)
    lowFractalLine := line.new(pivotBar, lowExtensionFractal, bar_index + 1, lowExtensionFractal, extend=extend.right, color=color.new(color.orange, 0), width=2)

highReturnedBeforeBar = highReturnedToIB
lowReturnedBeforeBar = lowReturnedToIB

longBosBeforeReturn = highBreakoutSeen and highFractalReady and not highReturnedBeforeBar and inTrade and close > highExtensionFractal
shortBosBeforeReturn = lowBreakoutSeen and lowFractalReady and not lowReturnedBeforeBar and inTrade and close < lowExtensionFractal

if longBosBeforeReturn or shortBosBeforeReturn
    extensionInvalidated := true

longExtensionSignal = highBreakoutSeen and highFractalReady and highReturnedBeforeBar and not extensionInvalidated and inTrade and not tradeTaken and close > highExtensionFractal
shortExtensionSignal = lowBreakoutSeen and lowFractalReady and lowReturnedBeforeBar and not extensionInvalidated and inTrade and not tradeTaken and close < lowExtensionFractal

highReturnToIB = highBreakoutSeen and highFractalReady and not highReturnedToIB and not extensionInvalidated and low <= ibHigh
lowReturnToIB = lowBreakoutSeen and lowFractalReady and not lowReturnedToIB and not extensionInvalidated and high >= ibLow

if highReturnToIB
    highReturnedToIB := true
if lowReturnToIB
    lowReturnedToIB := true

longExtension = longExtensionSignal and longAllowed
shortExtension = shortExtensionSignal and shortAllowed
if longExtension
    sl = ibLow
    tp = close + (close - sl)
    strategy.entry("IB Extension Long", strategy.long)
    strategy.exit("IB Extension Long 1R", "IB Extension Long", stop=sl, limit=tp)
    tradeTaken := true

if shortExtension
    sl = ibHigh
    tp = close - (sl - close)
    strategy.entry("IB Extension Short", strategy.short)
    strategy.exit("IB Extension Short 1R", "IB Extension Short", stop=sl, limit=tp)
    tradeTaken := true

plot((inIB or ibReady) ? ibHigh : na, "IB High", color=color.new(color.red, 0), linewidth=2, style=plot.style_linebr)
plot(showMid and ibReady ? ibMid : na, "IB 0.5", color=color.new(color.gray, 0), linewidth=1, style=plot.style_linebr)
plot((inIB or ibReady) ? ibLow : na, "IB Low", color=color.new(color.green, 0), linewidth=2, style=plot.style_linebr)
plot(highBreakoutSeen and not tradeTaken ? highExtensionFractal : na, "Extension High Fractal", color=color.new(color.yellow, 0), linewidth=2, style=plot.style_linebr)
plot(lowBreakoutSeen and not tradeTaken ? lowExtensionFractal : na, "Extension Low Fractal", color=color.new(color.orange, 0), linewidth=2, style=plot.style_linebr)
plot(showEMA ? emaFast : na, "15m EMA 125", color=color.new(color.purple, 0), linewidth=2)
plot(showEMA ? emaSlow : na, "15m EMA 200", color=color.new(color.fuchsia, 0), linewidth=2)

plotshape(ibStarted, title="IB Start", text="IB Start", style=shape.labelup, location=location.belowbar, color=color.new(color.blue, 0), textcolor=color.white, size=size.tiny)
plotshape(ibFinished, title="IB Ready", text="IB Ready", style=shape.labeldown, location=location.abovebar, color=color.new(color.gray, 0), textcolor=color.white, size=size.tiny)
plotshape(highBreakout, title="High Breakout", text="H Break", style=shape.triangledown, location=location.abovebar, color=color.new(color.yellow, 0), textcolor=color.black, size=size.tiny)
plotshape(lowBreakout, title="Low Breakout", text="L Break", style=shape.triangleup, location=location.belowbar, color=color.new(color.orange, 0), textcolor=color.black, size=size.tiny)
plotshape(newHighExtensionFractal, title="High Fractal", text="Fr H", style=shape.circle, location=location.abovebar, color=color.new(color.yellow, 0), textcolor=color.black, size=size.tiny, offset=-fractalRight)
plotshape(newLowExtensionFractal, title="Low Fractal", text="Fr L", style=shape.circle, location=location.belowbar, color=color.new(color.orange, 0), textcolor=color.black, size=size.tiny, offset=-fractalRight)
plotshape(highReturnToIB, title="High Return To IB", text="Ret", style=shape.diamond, location=location.belowbar, color=color.new(color.yellow, 0), textcolor=color.black, size=size.tiny)
plotshape(lowReturnToIB, title="Low Return To IB", text="Ret", style=shape.diamond, location=location.abovebar, color=color.new(color.orange, 0), textcolor=color.black, size=size.tiny)
plotshape(longBosBeforeReturn, title="Skipped Long BoS Before Return", text="Skip", style=shape.xcross, location=location.abovebar, color=color.new(color.red, 0), textcolor=color.white, size=size.tiny)
plotshape(shortBosBeforeReturn, title="Skipped Short BoS Before Return", text="Skip", style=shape.xcross, location=location.belowbar, color=color.new(color.red, 0), textcolor=color.white, size=size.tiny)
plotshape(longExtension, title="Extension Long", text="Ext L", style=shape.labelup, location=location.belowbar, color=color.new(color.green, 0), textcolor=color.white)
plotshape(shortExtension, title="Extension Short", text="Ext S", style=shape.labeldown, location=location.abovebar, color=color.new(color.red, 0), textcolor=color.white)

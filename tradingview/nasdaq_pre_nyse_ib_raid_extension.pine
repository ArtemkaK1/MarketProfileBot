//@version=5
strategy("NASDAQ Pre-NYSE IB Extension/Raid", overlay=true, initial_capital=100000, currency=currency.USD, process_orders_on_close=true, max_boxes_count=100, max_lines_count=300, max_labels_count=100)

// Draw the pre-NYSE Initial Balance and trade extension/raid entries.

ibSessionInput = input.session("0800-0930", "Pre-NYSE IB session")
tradeSessionInput = input.session("0930-1600", "Trade session")
timezoneInput = input.string("America/New_York", "Session timezone")
fractalLeft = input.int(1, "Fractal left bars", minval=1, maxval=10)
fractalRight = input.int(1, "Fractal right bars", minval=1, maxval=10)
breakoutNeedsClose = input.bool(false, "Breakout must close beyond IB")
enableExtensionLong = input.bool(true, "Enable extension long entries")
enableExtensionShort = input.bool(false, "Enable extension short entries")
enableRaidLong = input.bool(true, "Enable raid long entries")
enableRaidShort = input.bool(false, "Enable raid short entries")
webhookSecret = input.string("", "Webhook secret")
sendIBReadyAlert = input.bool(true, "Send IB ready alert")
riskCapital = input.float(100000.0, "Risk capital, USD", minval=1.0)
riskPercent = input.float(1.0, "Risk per trade, %", minval=0.1, maxval=100.0, step=0.1)
raidStopBufferTicks = input.int(1, "Raid SL buffer, ticks", minval=0, maxval=100)
emaTimeframe = input.timeframe("15", "EMA timeframe")
emaFastLength = input.int(125, "Fast EMA length", minval=1, maxval=500)
emaSlowLength = input.int(200, "Slow EMA length", minval=1, maxval=500)
showBox = input.bool(true, "Show IB box")
showMid = input.bool(true, "Show IB 0.5")
showEMA = input.bool(true, "Show 15m EMAs")
extendLevels = input.bool(true, "Extend levels right")

tz = timezoneInput
ibSession = ibSessionInput + ":23456"
tradeSession = tradeSessionInput + ":23456"
ibEndHour = int(str.tonumber(str.substring(ibSessionInput, 5, 7)))
ibEndMinute = int(str.tonumber(str.substring(ibSessionInput, 7, 9)))

inIB = not na(time(timeframe.period, ibSession, tz))
inTrade = not na(time(timeframe.period, tradeSession, tz))
flat = strategy.position_size == 0
newDay = ta.change(time("D", "0000-2359:1234567", tz)) != 0
ibStarted = inIB and not inIB[1]
ibFinished = inIB and hour(time_close, tz) == ibEndHour and minute(time_close, tz) == ibEndMinute

emaFast = request.security(syminfo.tickerid, emaTimeframe, ta.ema(close, emaFastLength), barmerge.gaps_off, barmerge.lookahead_off)
emaSlow = request.security(syminfo.tickerid, emaTimeframe, ta.ema(close, emaSlowLength), barmerge.gaps_off, barmerge.lookahead_off)
longAllowed = emaFast > emaSlow
shortAllowed = emaFast < emaSlow

positionQty(float entryPrice, float slPrice) =>
    stopDistance = math.abs(entryPrice - slPrice)
    riskCash = riskCapital * riskPercent / 100.0
    stopDistance > 0 and syminfo.pointvalue > 0 ? riskCash / (stopDistance * syminfo.pointvalue) : na

jsonString(string value) =>
    "\"" + str.replace_all(str.replace_all(value, "\\", "\\\\"), "\"", "\\\"") + "\""

jsonNumber(float value) =>
    str.tostring(value, format.mintick)

alertId(string alertType, string direction) =>
    payloadTime = alertType == "IB_READY" ? time_close : time
    str.replace_all(syminfo.tickerid, ":", "_") + "-" + str.format_time(payloadTime, "yyyyMMdd-HHmm", tz) + "-" + alertType + "-" + direction

jsonPayload(string alertType, string direction, float entryPrice, float ibH, float ibL, float ibM, float slPrice, float tpPrice) =>
    hasTradeLevels = alertType != "IB_READY"
    payloadTime = alertType == "IB_READY" ? time_close : time
    payload = "{"
    payload += "\"secret\":" + jsonString(webhookSecret)
    payload += ",\"id\":" + jsonString(alertId(alertType, direction))
    payload += ",\"type\":" + jsonString(alertType)
    payload += ",\"symbol\":" + jsonString(syminfo.ticker)
    payload += ",\"time\":" + jsonString(str.format_time(payloadTime, "yyyy-MM-dd'T'HH:mm:ssXXX", tz))
    payload += ",\"direction\":" + jsonString(direction)
    payload += ",\"price\":" + jsonNumber(entryPrice)
    payload += ",\"ib_high\":" + jsonNumber(ibH)
    payload += ",\"ib_low\":" + jsonNumber(ibL)
    payload += ",\"ib_mid\":" + jsonNumber(ibM)
    payload += ",\"sl\":" + (hasTradeLevels ? jsonNumber(slPrice) : "null")
    payload += ",\"tp\":" + (hasTradeLevels ? jsonNumber(tpPrice) : "null")
    payload += ",\"risk_percent\":" + str.tostring(riskPercent)
    payload += ",\"rr\":1.0"
    payload += ",\"source\":\"tradingview\""
    payload += "}"
    payload

var float ibHigh = na
var float ibLow = na
var float ibMid = na
var int ibStartBar = na
var bool ibReady = false
var bool tradeTaken = false

var bool highBreakoutSeen = false
var bool lowBreakoutSeen = false
var int highBreakoutBar = na
var int lowBreakoutBar = na
var float highExtensionFractal = na
var float lowExtensionFractal = na
var bool highFractalReady = false
var bool lowFractalReady = false
var bool highReturnedToIB = false
var bool lowReturnedToIB = false
var bool extensionInvalidated = false
var bool raidHighSeen = false
var bool raidLowSeen = false
var int raidFirstSide = 0
var int raidHighBar = na
var int raidLowBar = na
var float raidHighExtreme = na
var float raidLowExtreme = na
var float raidHighFractal = na
var float raidLowFractal = na
var bool raidHighFractalReady = false
var bool raidLowFractalReady = false
var bool raidHighReturnedToIB = false
var bool raidLowReturnedToIB = false
var int raidHighCount = 0
var int raidLowCount = 0

var box ibBox = na
var line ibHighLine = na
var line ibMidLine = na
var line ibLowLine = na
var line highFractalLine = na
var line lowFractalLine = na
var label ibLabel = na

deleteDrawings() =>
    if not na(ibBox)
        box.delete(ibBox)
    if not na(ibHighLine)
        line.delete(ibHighLine)
    if not na(ibMidLine)
        line.delete(ibMidLine)
    if not na(ibLowLine)
        line.delete(ibLowLine)
    if not na(highFractalLine)
        line.delete(highFractalLine)
    if not na(lowFractalLine)
        line.delete(lowFractalLine)
    if not na(ibLabel)
        label.delete(ibLabel)

if newDay
    deleteDrawings()
    ibHigh := na
    ibLow := na
    ibMid := na
    ibStartBar := na
    ibReady := false
    tradeTaken := false
    highBreakoutSeen := false
    lowBreakoutSeen := false
    highBreakoutBar := na
    lowBreakoutBar := na
    highExtensionFractal := na
    lowExtensionFractal := na
    highFractalReady := false
    lowFractalReady := false
    highReturnedToIB := false
    lowReturnedToIB := false
    extensionInvalidated := false
    raidHighSeen := false
    raidLowSeen := false
    raidFirstSide := 0
    raidHighBar := na
    raidLowBar := na
    raidHighExtreme := na
    raidLowExtreme := na
    raidHighFractal := na
    raidLowFractal := na
    raidHighFractalReady := false
    raidLowFractalReady := false
    raidHighReturnedToIB := false
    raidLowReturnedToIB := false
    raidHighCount := 0
    raidLowCount := 0
    ibBox := na
    ibHighLine := na
    ibMidLine := na
    ibLowLine := na
    highFractalLine := na
    lowFractalLine := na
    ibLabel := na

if ibStarted
    deleteDrawings()
    ibHigh := high
    ibLow := low
    ibMid := na
    ibStartBar := bar_index
    ibReady := false
    tradeTaken := false
    highBreakoutSeen := false
    lowBreakoutSeen := false
    highBreakoutBar := na
    lowBreakoutBar := na
    highExtensionFractal := na
    lowExtensionFractal := na
    highFractalReady := false
    lowFractalReady := false
    highReturnedToIB := false
    lowReturnedToIB := false
    extensionInvalidated := false
    raidHighSeen := false
    raidLowSeen := false
    raidFirstSide := 0
    raidHighBar := na
    raidLowBar := na
    raidHighExtreme := na
    raidLowExtreme := na
    raidHighFractal := na
    raidLowFractal := na
    raidHighFractalReady := false
    raidLowFractalReady := false
    raidHighReturnedToIB := false
    raidLowReturnedToIB := false
    raidHighCount := 0
    raidLowCount := 0
    ibBox := na
    ibHighLine := na
    ibMidLine := na
    ibLowLine := na
    highFractalLine := na
    lowFractalLine := na
    ibLabel := na

if inIB
    ibHigh := na(ibHigh) ? high : math.max(ibHigh, high)
    ibLow := na(ibLow) ? low : math.min(ibLow, low)
    if showBox
        if na(ibBox)
            ibBox := box.new(ibStartBar, ibHigh, bar_index, ibLow, bgcolor=color.new(color.blue, 88), border_color=color.new(color.blue, 20))
        else
            box.set_left(ibBox, ibStartBar)
            box.set_right(ibBox, bar_index)
            box.set_top(ibBox, ibHigh)
            box.set_bottom(ibBox, ibLow)

if ibFinished and not na(ibHigh) and not na(ibLow)
    ibMid := (ibHigh + ibLow) / 2.0
    ibReady := true
    x2 = extendLevels ? bar_index + 1 : bar_index
    levelExtend = extendLevels ? extend.right : extend.none
    ibHighLine := line.new(bar_index, ibHigh, x2, ibHigh, extend=levelExtend, color=color.new(color.red, 0), width=2)
    if showMid
        ibMidLine := line.new(bar_index, ibMid, x2, ibMid, extend=levelExtend, color=color.new(color.gray, 0), width=1, style=line.style_dashed)
    ibLowLine := line.new(bar_index, ibLow, x2, ibLow, extend=levelExtend, color=color.new(color.green, 0), width=2)
    ibLabel := label.new(bar_index, ibHigh, "Pre-NYSE IB", style=label.style_label_down, color=color.new(color.blue, 0), textcolor=color.white)
    if sendIBReadyAlert and webhookSecret != ""
        alert(jsonPayload("IB_READY", "NONE", close, ibHigh, ibLow, ibMid, na, na), alert.freq_once_per_bar_close)

highBreakout = ibReady and inTrade and flat and not tradeTaken and not highBreakoutSeen and not lowBreakoutSeen and (breakoutNeedsClose ? close > ibHigh : high > ibHigh)
lowBreakout = ibReady and inTrade and flat and not tradeTaken and not highBreakoutSeen and not lowBreakoutSeen and not highBreakout and (breakoutNeedsClose ? close < ibLow : low < ibLow)

if highBreakout
    highBreakoutSeen := true
    highBreakoutBar := bar_index
if lowBreakout
    lowBreakoutSeen := true
    lowBreakoutBar := bar_index

raidHighBeyondIB = breakoutNeedsClose ? close > ibHigh : high > ibHigh
raidLowBeyondIB = breakoutNeedsClose ? close < ibLow : low < ibLow
raidAmbiguousBar = ibReady and inTrade and flat and not tradeTaken and raidHighBeyondIB and raidLowBeyondIB
raidHighNextWindow = raidFirstSide == -1 and raidHighSeen and bar_index == raidHighBar + 1 and not raidHighFractalReady
raidLowNextWindow = raidFirstSide == 1 and raidLowSeen and bar_index == raidLowBar + 1 and not raidLowFractalReady
nextBarRaidLongSignal = not raidAmbiguousBar and raidHighNextWindow and close > ibHigh and high > raidHighExtreme
nextBarRaidShortSignal = not raidAmbiguousBar and raidLowNextWindow and close < ibLow and low < raidLowExtreme
// A completed return makes that side eligible for another independent raid cycle.
canStartRaidHigh = raidFirstSide == 0 or (raidHighSeen ? raidHighReturnedToIB : raidFirstSide == -1 and raidLowReturnedToIB)
canStartRaidLow = raidFirstSide == 0 or (raidLowSeen ? raidLowReturnedToIB : raidFirstSide == 1 and raidHighReturnedToIB)
raidHighBreakout = ibReady and inTrade and flat and not tradeTaken and not raidAmbiguousBar and not raidHighNextWindow and canStartRaidHigh and raidHighBeyondIB
raidLowBreakout = ibReady and inTrade and flat and not tradeTaken and not raidAmbiguousBar and not raidLowNextWindow and canStartRaidLow and raidLowBeyondIB

if raidHighBreakout
    highIsFirstSideReraid = raidFirstSide == 1
    raidHighSeen := true
    raidFirstSide := raidFirstSide == 0 ? 1 : raidFirstSide
    raidHighBar := bar_index
    raidHighExtreme := high
    raidHighCount += 1
    raidHighFractal := na
    raidHighFractalReady := false
    raidHighReturnedToIB := false
    if highIsFirstSideReraid
        raidLowSeen := false
        raidLowBar := na
        raidLowExtreme := na
        raidLowFractal := na
        raidLowFractalReady := false
        raidLowReturnedToIB := false
if raidLowBreakout
    lowIsFirstSideReraid = raidFirstSide == -1
    raidLowSeen := true
    raidFirstSide := raidFirstSide == 0 ? -1 : raidFirstSide
    raidLowBar := bar_index
    raidLowExtreme := low
    raidLowCount += 1
    raidLowFractal := na
    raidLowFractalReady := false
    raidLowReturnedToIB := false
    if lowIsFirstSideReraid
        raidHighSeen := false
        raidHighBar := na
        raidHighExtreme := na
        raidHighFractal := na
        raidHighFractalReady := false
        raidHighReturnedToIB := false

if raidHighSeen and not raidHighReturnedToIB and not tradeTaken and high > ibHigh
    raidHighExtreme := na(raidHighExtreme) ? high : math.max(raidHighExtreme, high)
if raidLowSeen and not raidLowReturnedToIB and not tradeTaken and low < ibLow
    raidLowExtreme := na(raidLowExtreme) ? low : math.min(raidLowExtreme, low)

raidHighReturnedOnBar = raidHighSeen and close <= ibHigh
raidLowReturnedOnBar = raidLowSeen and close >= ibLow

if not raidHighReturnedToIB and raidHighReturnedOnBar
    raidHighReturnedToIB := true
if not raidLowReturnedToIB and raidLowReturnedOnBar
    raidLowReturnedToIB := true

pivotHigh = ta.pivothigh(high, fractalLeft, fractalRight)
pivotLow = ta.pivotlow(low, fractalLeft, fractalRight)
pivotBar = bar_index - fractalRight

newHighExtensionFractal = highBreakoutSeen and not na(pivotHigh) and pivotBar >= highBreakoutBar and pivotHigh > ibHigh
newLowExtensionFractal = lowBreakoutSeen and not na(pivotLow) and pivotBar >= lowBreakoutBar and pivotLow < ibLow

if newHighExtensionFractal
    highExtensionFractal := pivotHigh
    highFractalReady := true
    if not na(highFractalLine)
        line.delete(highFractalLine)
    highFractalLine := line.new(pivotBar, highExtensionFractal, bar_index + 1, highExtensionFractal, extend=extend.right, color=color.new(color.yellow, 0), width=2)

if newLowExtensionFractal
    lowExtensionFractal := pivotLow
    lowFractalReady := true
    if not na(lowFractalLine)
        line.delete(lowFractalLine)
    lowFractalLine := line.new(pivotBar, lowExtensionFractal, bar_index + 1, lowExtensionFractal, extend=extend.right, color=color.new(color.orange, 0), width=2)

newRaidHighFractal = raidHighSeen and not na(pivotHigh) and pivotBar >= raidHighBar and pivotHigh > ibHigh
newRaidLowFractal = raidLowSeen and not na(pivotLow) and pivotBar >= raidLowBar and pivotLow < ibLow

if newRaidHighFractal
    raidHighFractal := pivotHigh
    raidHighFractalReady := true
if newRaidLowFractal
    raidLowFractal := pivotLow
    raidLowFractalReady := true

highReturnedBeforeBar = highReturnedToIB
lowReturnedBeforeBar = lowReturnedToIB

longBosBeforeReturn = highBreakoutSeen and highFractalReady and not highReturnedBeforeBar and inTrade and close > highExtensionFractal
shortBosBeforeReturn = lowBreakoutSeen and lowFractalReady and not lowReturnedBeforeBar and inTrade and close < lowExtensionFractal

if longBosBeforeReturn or shortBosBeforeReturn
    extensionInvalidated := true

longExtensionSignal = highBreakoutSeen and not lowBreakoutSeen and highFractalReady and highReturnedBeforeBar and not extensionInvalidated and inTrade and flat and not tradeTaken and close > highExtensionFractal
shortExtensionSignal = lowBreakoutSeen and not highBreakoutSeen and lowFractalReady and lowReturnedBeforeBar and not extensionInvalidated and inTrade and flat and not tradeTaken and close < lowExtensionFractal

highReturnToIB = highBreakoutSeen and highFractalReady and not highReturnedToIB and not extensionInvalidated and low <= ibHigh
lowReturnToIB = lowBreakoutSeen and lowFractalReady and not lowReturnedToIB and not extensionInvalidated and high >= ibLow

if highReturnToIB
    highReturnedToIB := true
if lowReturnToIB
    lowReturnedToIB := true

longExtension = enableExtensionLong and longExtensionSignal and longAllowed
shortExtension = enableExtensionShort and shortExtensionSignal and shortAllowed
directRaidShortSignal = raidFirstSide == 1 and raidLowBreakout and not raidLowFractalReady and close < ibLow
directRaidLongSignal = raidFirstSide == -1 and raidHighBreakout and not raidHighFractalReady and close > ibHigh
fractalBosRaidShortSignal = raidFirstSide == 1 and raidLowSeen and raidLowFractalReady and close < raidLowFractal and close[1] >= raidLowFractal
fractalBosRaidLongSignal = raidFirstSide == -1 and raidHighSeen and raidHighFractalReady and close > raidHighFractal and close[1] <= raidHighFractal
raidLongSignal = inTrade and flat and not tradeTaken and (directRaidLongSignal or nextBarRaidLongSignal or fractalBosRaidLongSignal)
raidShortSignal = inTrade and flat and not tradeTaken and (directRaidShortSignal or nextBarRaidShortSignal or fractalBosRaidShortSignal)
raidLong = enableRaidLong and raidLongSignal and longAllowed
raidShort = enableRaidShort and raidShortSignal and shortAllowed

if raidShort
    raidShortMode = directRaidShortSignal ? "DIRECT" : nextBarRaidShortSignal ? "NEXT" : "FRACTAL"
    raidShortComment = "Raid Short " + raidShortMode + " H" + str.tostring(raidHighCount) + " L" + str.tostring(raidLowCount)
    sl = raidHighExtreme + raidStopBufferTicks * syminfo.mintick
    tp = close - (sl - close)
    qty = positionQty(close, sl)
    strategy.entry("IB Raid Short", strategy.short, qty=qty, comment=raidShortComment)
    strategy.exit("IB Raid Short 1R", "IB Raid Short", stop=sl, limit=tp)
    if webhookSecret != ""
        alert(jsonPayload("RAID", "SHORT", close, ibHigh, ibLow, ibMid, sl, tp), alert.freq_once_per_bar_close)
    tradeTaken := true

if raidLong
    raidLongMode = directRaidLongSignal ? "DIRECT" : nextBarRaidLongSignal ? "NEXT" : "FRACTAL"
    raidLongComment = "Raid Long " + raidLongMode + " H" + str.tostring(raidHighCount) + " L" + str.tostring(raidLowCount)
    sl = raidLowExtreme - raidStopBufferTicks * syminfo.mintick
    tp = close + (close - sl)
    qty = positionQty(close, sl)
    strategy.entry("IB Raid Long", strategy.long, qty=qty, comment=raidLongComment)
    strategy.exit("IB Raid Long 1R", "IB Raid Long", stop=sl, limit=tp)
    if webhookSecret != ""
        alert(jsonPayload("RAID", "LONG", close, ibHigh, ibLow, ibMid, sl, tp), alert.freq_once_per_bar_close)
    tradeTaken := true

if longExtension
    sl = ibLow
    tp = close + (close - sl)
    qty = positionQty(close, sl)
    strategy.entry("IB Extension Long", strategy.long, qty=qty)
    strategy.exit("IB Extension Long 1R", "IB Extension Long", stop=sl, limit=tp)
    if webhookSecret != ""
        alert(jsonPayload("EXTENSION", "LONG", close, ibHigh, ibLow, ibMid, sl, tp), alert.freq_once_per_bar_close)
    tradeTaken := true

if shortExtension
    sl = ibHigh
    tp = close - (sl - close)
    qty = positionQty(close, sl)
    strategy.entry("IB Extension Short", strategy.short, qty=qty)
    strategy.exit("IB Extension Short 1R", "IB Extension Short", stop=sl, limit=tp)
    if webhookSecret != ""
        alert(jsonPayload("EXTENSION", "SHORT", close, ibHigh, ibLow, ibMid, sl, tp), alert.freq_once_per_bar_close)
    tradeTaken := true

plot((inIB or ibReady) ? ibHigh : na, "IB High", color=color.new(color.red, 0), linewidth=2, style=plot.style_linebr)
plot(showMid and ibReady ? ibMid : na, "IB 0.5", color=color.new(color.gray, 0), linewidth=1, style=plot.style_linebr)
plot((inIB or ibReady) ? ibLow : na, "IB Low", color=color.new(color.green, 0), linewidth=2, style=plot.style_linebr)
plot(highBreakoutSeen and not tradeTaken ? highExtensionFractal : na, "Extension High Fractal", color=color.new(color.yellow, 0), linewidth=2, style=plot.style_linebr)
plot(lowBreakoutSeen and not tradeTaken ? lowExtensionFractal : na, "Extension Low Fractal", color=color.new(color.orange, 0), linewidth=2, style=plot.style_linebr)
plot(raidHighSeen and not tradeTaken ? raidHighFractal : na, "Raid High Fractal", color=color.new(color.yellow, 45), linewidth=1, style=plot.style_linebr)
plot(raidLowSeen and not tradeTaken ? raidLowFractal : na, "Raid Low Fractal", color=color.new(color.orange, 45), linewidth=1, style=plot.style_linebr)
plot(showEMA ? emaFast : na, "15m EMA 125", color=color.new(color.purple, 0), linewidth=2)
plot(showEMA ? emaSlow : na, "15m EMA 200", color=color.new(color.fuchsia, 0), linewidth=2)

plotshape(ibStarted, title="IB Start", text="IB Start", style=shape.labelup, location=location.belowbar, color=color.new(color.blue, 0), textcolor=color.white, size=size.tiny)
plotshape(ibFinished, title="IB Ready", text="IB Ready", style=shape.labeldown, location=location.abovebar, color=color.new(color.gray, 0), textcolor=color.white, size=size.tiny)
plotshape(highBreakout, title="High Breakout", text="H Break", style=shape.triangledown, location=location.abovebar, color=color.new(color.yellow, 0), textcolor=color.black, size=size.tiny)
plotshape(lowBreakout, title="Low Breakout", text="L Break", style=shape.triangleup, location=location.belowbar, color=color.new(color.orange, 0), textcolor=color.black, size=size.tiny)
plotshape(newHighExtensionFractal, title="High Fractal", text="Fr H", style=shape.circle, location=location.abovebar, color=color.new(color.yellow, 0), textcolor=color.black, size=size.tiny, offset=-fractalRight)
plotshape(newLowExtensionFractal, title="Low Fractal", text="Fr L", style=shape.circle, location=location.belowbar, color=color.new(color.orange, 0), textcolor=color.black, size=size.tiny, offset=-fractalRight)
plotshape(highReturnToIB, title="High Return To IB", text="Ret", style=shape.diamond, location=location.belowbar, color=color.new(color.yellow, 0), textcolor=color.black, size=size.tiny)
plotshape(lowReturnToIB, title="Low Return To IB", text="Ret", style=shape.diamond, location=location.abovebar, color=color.new(color.orange, 0), textcolor=color.black, size=size.tiny)
plotshape(longBosBeforeReturn, title="Skipped Long BoS Before Return", text="Skip", style=shape.xcross, location=location.abovebar, color=color.new(color.red, 0), textcolor=color.white, size=size.tiny)
plotshape(shortBosBeforeReturn, title="Skipped Short BoS Before Return", text="Skip", style=shape.xcross, location=location.belowbar, color=color.new(color.red, 0), textcolor=color.white, size=size.tiny)
plotshape(raidAmbiguousBar, title="Ambiguous Two-Sided Raid", text="2-Side", style=shape.xcross, location=location.abovebar, color=color.new(color.gray, 0), textcolor=color.white, size=size.tiny)
plotshape(raidLong, title="Raid Long", text="Raid L", style=shape.labelup, location=location.belowbar, color=color.new(color.lime, 0), textcolor=color.black)
plotshape(raidShort, title="Raid Short", text="Raid S", style=shape.labeldown, location=location.abovebar, color=color.new(color.maroon, 0), textcolor=color.white)
plotshape(longExtension, title="Extension Long", text="Ext L", style=shape.labelup, location=location.belowbar, color=color.new(color.green, 0), textcolor=color.white)
plotshape(shortExtension, title="Extension Short", text="Ext S", style=shape.labeldown, location=location.abovebar, color=color.new(color.red, 0), textcolor=color.white)
